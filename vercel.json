{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.{css,js}",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.{jpeg,jpg,png,gif,svg}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    }
  ]
}
